/-  t  /add/two
:-  /ud
=,  grubberyio
=/  m  (charm:base:g ,~)
^-  form:m
;<  [=stud:g =vase]  bind:m  get-poke-pail
?+    stud  !!
    [%counter %inc ~]
  ;<  a=@ud  bind:m  (get-state-as @ud)
  (pour !>(+(a)))
  ::
    [%counter %two ~]
  ;<  a=@ud  bind:m  (get-state-as @ud)
  (pour !>((two:t a)))
==
